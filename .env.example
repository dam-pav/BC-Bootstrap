WINDOWS_TAG=ltsc2022
BCCONTAINERHELPER_VERSION=latest
DOCKER_ISOLATION=process
HOST_DOCKER_PATH=C:\docker

# Must be an existing absolute Windows host path. Keep the target path identical.
HOST_FILES_PATH=C:\BcBootstrapFiles

# Directory containing parameters.json and bccontainerhelper.config.json.
# Use an absolute host path when deploying through Portainer.
HOST_CONFIG_PATH=.\config

BCC_COMMAND=New-BcContainer
BCC_CONFIG_FILENAME=bccontainerhelper.config.json
BCC_PARAMETERS_FILENAME=parameters.json
BCC_CONTAINER_NAME=bc-bootstrap-test

# GitHub repository in owner/repository form. When set, the bootstrap downloads
# both config files from its config/ directory. A token is required for private repos.
GITHUB_REPO=
GITHUB_TOKEN=

BCC_PARAMETERS_JSON=
BCC_CREDENTIAL_USERNAME=admin
BCC_CREDENTIAL_PASSWORD=ChangeMe123!
BCC_DRY_RUN=false

# Add any New-BcContainer parameter without changing the image. Values that look
# like JSON are typed; all other values remain strings.
# BCC_PARAM_includeAL=true
# BCC_PARAM_additionalParameters=["--publish 8080:8080","--volume C:\\BcBootstrapFiles:C:\\run\\my"]
