WINDOWS_TAG=ltsc2022
BCCONTAINERHELPER_VERSION=latest
DOCKER_VERSION=27.5.1
SEVENZIP_VERSION=2602
DOCKER_ISOLATION=process

# Must be an existing absolute Windows host path. Keep the target path identical.
HOST_FILES_PATH=C:\BcBootstrapFiles

BCC_COMMAND=New-BcContainer
BCC_CONFIG_FILE=C:\bootstrap\config\bccontainerhelper.config.json
BCC_PARAMETERS_FILE=C:\bootstrap\config\parameters.json
BCC_PARAMETERS_JSON=
BCC_CREDENTIAL_USERNAME=admin
BCC_CREDENTIAL_PASSWORD=ChangeMe123!
BCC_DRY_RUN=false

# Add any New-BcContainer parameter without changing the image. Values that look
# like JSON are typed; all other values remain strings.
# BCC_PARAM_includeAL=true
# BCC_PARAM_additionalParameters=["--publish 8080:8080","--volume C:\\BcBootstrapFiles:C:\\run\\my"]
